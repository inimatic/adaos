{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adaos.webui.v1",
  "title": "AdaOS Skill WebUI Manifest (webui.json)",
  "description": "Declarative UI contributions for a skill. Merged by WebspaceScenarioRuntime into ui.application / data.catalog / registry.merged.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string", "description": "Optional JSON Schema reference for editors/validators." },

    "catalog": { "$ref": "#/$defs/catalog" },
    "apps": { "$ref": "#/$defs/catalogApps" },
    "widgets": { "$ref": "#/$defs/catalogWidgets" },

    "registry": { "$ref": "#/$defs/registry" },
    "resources": {
      "$ref": "#/$defs/uiResources",
      "description": "Skill UI resources resolved by the AdaOS runtime and browser client, not by arbitrary skill-hosted static routes."
    },
    "nlu": { "$ref": "#/$defs/nluDescriptor" },
    "llm_hints": {
      "$ref": "#/$defs/authoringHints",
      "description": "Builder-readable UI contribution hints for AI-assisted and human authoring workflows."
    },
    "nlu_hints": {
      "$ref": "#/$defs/authoringHints",
      "description": "Builder-readable NLU hints for UI aliases, examples, slot schemas, entities, and owner routing."
    },
    "voice_capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/voiceCapability" },
      "description": "Public user-facing capabilities that may be addressed by voice or typed conversational input."
    },
    "voice_affordances": {
      "type": "array",
      "items": { "$ref": "#/$defs/voiceAffordance" },
      "description": "Voice-addressable UI targets such as modal tabs, sections, filters, buttons, and reachable panels."
    },
    "webio": { "$ref": "#/$defs/webio" },
    "ydoc_defaults": {
      "description": "Default Yjs values applied once per webspace. Keys are 'root/key' paths (e.g. 'data/voice_chat').",
      "type": "object",
      "additionalProperties": true
    },
    "contributions": {
      "description": "Declarative contributions to extension points (e.g. auto-install apps/widgets).",
      "type": "array",
      "items": { "$ref": "#/$defs/contribution" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier; may include ':' for synthetic ids (e.g. 'scenario:<id>')."
    },
    "nluDescriptor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "llm_hints": { "$ref": "#/$defs/authoringHints" },
        "nlu_hints": { "$ref": "#/$defs/authoringHints" }
      }
    },
    "authoringHints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "primary_actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/authoringActionHint" }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/authoringActionHint" }
        },
        "examples": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/authoringExample" }
            ]
          }
        },
        "slot_schemas": { "type": "object", "additionalProperties": true },
        "entities": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/authoringEntityHint" }
            ]
          }
        },
        "owner_hints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "side_effect_class": {
          "type": "string",
          "enum": ["none", "read_only", "local_write", "runtime_write", "external_io", "destructive"]
        },
        "notes": { "type": "string" }
      }
    },
    "authoringActionHint": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "intent": { "type": "string", "minLength": 1 },
        "tool": { "type": "string", "minLength": 1 },
        "event": { "type": "string", "minLength": 1 },
        "slots": { "type": "object", "additionalProperties": true },
        "examples": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "side_effect_class": {
          "type": "string",
          "enum": ["none", "read_only", "local_write", "runtime_write", "external_io", "destructive"]
        }
      }
    },
    "authoringExample": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "slots": { "type": "object", "additionalProperties": true }
      },
      "required": ["text"]
    },
    "voiceCapability": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parameters": { "type": "object", "additionalProperties": true },
        "result_modes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "default_result_mode": { "type": "string", "minLength": 1 },
        "side_effect_class": { "type": "string", "minLength": 1 },
        "activation": {
          "type": "array",
          "items": { "$ref": "#/$defs/voiceActivationStep" }
        },
        "verify": { "type": "object", "additionalProperties": true }
      }
    },
    "voiceAffordance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "parent": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "locale": { "type": "string" },
        "visibility": { "type": "object", "additionalProperties": true },
        "side_effect_class": { "type": "string", "minLength": 1 },
        "activation": {
          "type": "array",
          "items": { "$ref": "#/$defs/voiceActivationStep" }
        },
        "verify": { "type": "object", "additionalProperties": true }
      }
    },
    "voiceActivationStep": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "params": { "type": "object", "additionalProperties": true }
      }
    },
    "authoringEntityHint": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "canonical_ref": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "uiResources": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/uiResource" },
      "description": "Map of stable resource ids to browser-facing static assets. References use resource:<id> tokens from icons, images, inputs, or semantic config."
    },
    "uiResource": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["icon", "image", "svg", "font", "stylesheet", "template", "data"],
          "description": "Semantic resource role. The browser decides the concrete renderer/cache behavior."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Skill-relative or package-relative path. Runtime must normalize and serve it through the core channel."
        },
        "url": {
          "type": "string",
          "description": "Optional already-resolved URL, usually produced by runtime materialization rather than authored by a skill."
        },
        "mime": { "type": "string" },
        "title": { "type": "string" },
        "alt": { "type": "string" },
        "cacheKey": {
          "type": "string",
          "description": "Stable cache key such as sha256:<digest>; changes invalidate browser caches."
        },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "delivery": {
          "type": "string",
          "enum": ["core", "external"],
          "default": "core",
          "description": "core means the asset is delivered by AdaOS over the active browser/core channel."
        },
        "scope": {
          "type": "string",
          "enum": ["skill", "scenario", "system", "external"],
          "default": "skill"
        },
        "fallback": {}
      }
    },
    "loadPhase": {
      "type": "string",
      "enum": ["eager", "visible", "interaction", "deferred"],
      "description": "Coarse-grained load intent for a surface or data branch."
    },
    "focusPhase": {
      "type": "string",
      "enum": ["primary", "supporting", "off_focus", "background"],
      "description": "Relative focus priority for staged or multi-surface interfaces."
    },
    "widgetType": {
      "type": "string",
      "enum": [
        "collection.grid",
        "collection.tree",
        "visual.taigaCollectionGrid",
        "visual.taigaMetricChart",
        "visual.frameViewer",
        "visual.image",
        "visual.metricTile",
        "visual.metricChart",
        "visual.timeseriesChart",
        "visual.qrCode",
        "feedback.log",
        "feedback.statusBar",
        "ui.chat",
        "ui.voiceInput",
        "ui.voiceDebug",
        "ui.list",
        "ui.table",
        "ui.form",
        "ui.actions",
        "ui.jsonViewer",
        "item.textEditor",
        "item.codeViewer",
        "item.details",
        "input.commandBar",
        "input.fileUpload",
        "input.frameSlider",
        "input.text",
        "input.selector",
        "desktop.widgets",
        "media.videoBrowser",
        "host.webspaceControls"
      ],
      "description": "Client-supported widget renderer type."
    },
    "readinessState": {
      "type": "string",
      "enum": ["pending_structure", "first_paint", "interactive", "hydrating", "ready", "degraded"],
      "description": "Expected readiness contract token surfaced while off-focus hydration is still in progress."
    },
    "loadHint": {
      "type": "object",
      "additionalProperties": false,
      "description": "Intent-level staged rendering hints. These are not scheduler commands.",
      "properties": {
        "structure": { "$ref": "#/$defs/loadPhase" },
        "data": { "$ref": "#/$defs/loadPhase" },
        "focus": { "$ref": "#/$defs/focusPhase" },
        "offFocusReadyState": { "$ref": "#/$defs/readinessState" }
      }
    },
    "initialFocus": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["ref"],
          "properties": {
            "ref": {
              "type": "string",
              "minLength": 1,
              "description": "Semantic target ref such as widget:search-box or control:city."
            },
            "strategy": {
              "type": "string",
              "enum": ["first_available", "restore_or_first", "always"],
              "default": "restore_or_first"
            },
            "required": {
              "type": "boolean",
              "description": "When true, missing focus target is a manifest/design issue instead of a silent no-op."
            }
          }
        }
      ]
    },
    "submitBehavior": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultAction": {
          "type": "string",
          "minLength": 1,
          "description": "Action id/ref invoked when Enter submits the current form context."
        },
        "enterKey": {
          "type": "string",
          "enum": ["submit", "newline", "ignore"],
          "default": "submit"
        },
        "scope": {
          "type": "string",
          "enum": ["focused_form", "widget", "surface"],
          "default": "focused_form"
        },
        "allowTextAreaNewline": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "interactionBehavior": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "initialFocus": { "$ref": "#/$defs/initialFocus" },
        "submit": { "$ref": "#/$defs/submitBehavior" },
        "defaultAction": {
          "type": "string",
          "minLength": 1,
          "description": "Shortcut for submit.defaultAction on simple widgets/surfaces."
        }
      }
    },
    "loadingBehavior": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "statePath": {
          "type": "string",
          "minLength": 1,
          "description": "Optional Yjs/view-state path that carries loading/status information."
        },
        "readyWhen": {
          "type": "string",
          "description": "Client expression for considering the element ready."
        },
        "loadingText": { "type": "string" },
        "emptyText": { "type": "string" },
        "degradedText": { "type": "string" },
        "skeleton": {
          "type": "string",
          "enum": ["none", "line", "card", "table", "chart", "custom"]
        },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "retainLastValue": {
          "type": "boolean",
          "description": "Keep the last rendered value while a fresh value is loading or stale."
        }
      }
    },

    "catalog": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "apps": { "$ref": "#/$defs/catalogApps" },
        "widgets": { "$ref": "#/$defs/catalogWidgets" }
      }
    },
    "catalogApps": {
      "type": "array",
      "items": { "$ref": "#/$defs/app" }
    },
    "catalogWidgets": {
      "type": "array",
      "items": { "$ref": "#/$defs/widgetCatalogEntry" }
    },

    "launchAction": {
      "type": "object",
      "additionalProperties": true,
      "description": "Compact catalog launch action used by desktop app tiles.",
      "properties": {
        "openModal": { "$ref": "#/$defs/id" },
        "openOverlay": { "$ref": "#/$defs/id" },
        "openWorkspace": { "$ref": "#/$defs/id" },
        "url": { "type": "string" }
      }
    },

    "app": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "icon": { "type": "string", "description": "Ionicon name (e.g. 'mic-outline') or resource:<id>." },
        "launchModal": { "$ref": "#/$defs/id" },
        "action": { "$ref": "#/$defs/launchAction" },
        "url": { "type": "string" },
        "load": { "$ref": "#/$defs/loadHint" }
      }
    },

    "widgetCatalogEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "$ref": "#/$defs/widgetType" },
        "title": { "type": "string" },
        "area": { "type": "string", "description": "Optional default area when pinned as a widget." },
        "dataSource": { "$ref": "#/$defs/dataSource" },
        "inputs": { "type": "object", "additionalProperties": true },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
        "load": { "$ref": "#/$defs/loadHint" },
        "loading": { "$ref": "#/$defs/loadingBehavior" },
        "interaction": { "$ref": "#/$defs/interactionBehavior" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "visual.frameViewer" } } },
          "then": {
            "properties": {
              "inputs": { "$ref": "#/$defs/frameViewerInputs" }
            }
          }
        }
      ]
    },

    "registry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "modals": {
          "description": "Modal registry. Can be a map {id: modalDef} or an array of modal ids (legacy).",
          "oneOf": [
            { "$ref": "#/$defs/modalMap" },
            { "type": "array", "items": { "$ref": "#/$defs/id" } }
          ]
        },
        "widgets": {
          "description": "Widget registry. Can be a map {id: widgetDef} or an array of widget ids (legacy).",
          "oneOf": [
            { "$ref": "#/$defs/widgetRegistryMap" },
            { "type": "array", "items": { "$ref": "#/$defs/id" } }
          ]
        }
      }
    },

    "modalMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/modalDef" }
    },
    "modalDef": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "schema": { "$ref": "#/$defs/pageSchema" },
        "load": { "$ref": "#/$defs/loadHint" },
        "loading": { "$ref": "#/$defs/loadingBehavior" },
        "presentation": { "$ref": "#/$defs/overlayPresentation" },
        "overlay": {
          "$ref": "#/$defs/overlayPresentation",
          "description": "Alias for presentation kept for manifests that model modals as overlays."
        }
      }
    },

    "overlayPresentation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Runtime overlay presentation contract. The renderer owns mechanics such as Ionic modal, sheet, or drawer, while the manifest declares lifecycle intent.",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["modal", "sheet", "sideSheet", "popover", "drawer", "fullscreen"],
          "description": "Renderer intent hint for the overlay shape."
        },
        "focus": { "$ref": "#/$defs/overlayFocusPolicy" },
        "restoreFocus": {
          "type": "boolean",
          "description": "Shortcut for focus.restoreOrigin. Defaults to true."
        }
      }
    },

    "overlayFocusPolicy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Focus lifecycle policy for runtime-owned overlays. Defaults protect accessibility by releasing hidden background focus and restoring the opener after dismissal.",
      "properties": {
        "captureOrigin": {
          "type": "boolean",
          "default": true,
          "description": "Capture the active element before opening so it can be restored later."
        },
        "releaseBackground": {
          "type": "boolean",
          "default": true,
          "description": "Blur focused background elements before the renderer hides the background surface."
        },
        "restoreOrigin": {
          "type": "boolean",
          "default": true,
          "description": "Restore focus to the captured origin after the overlay closes, when still connected and visible."
        }
      }
    },

    "widgetRegistryMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/widgetCatalogEntry" }
    },

    "pageSchema": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "layout", "widgets"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string" },
        "layout": { "$ref": "#/$defs/layout" },
        "widgets": { "type": "array", "items": { "$ref": "#/$defs/widgetConfig" } },
        "load": { "$ref": "#/$defs/loadHint" },
        "loading": { "$ref": "#/$defs/loadingBehavior" },
        "interaction": { "$ref": "#/$defs/interactionBehavior" },
        "initialState": {
          "type": "object",
          "additionalProperties": true,
          "description": "Local page/modal state defaults applied only for keys that are not already set."
        },
        "autoActions": {
          "type": "array",
          "items": { "$ref": "#/$defs/autoAction" },
          "description": "Lightweight interval actions active only while this page/modal is mounted."
        },
        "semantic": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional semantic UI layer consumed by the client adapter."
        },
        "surfaceClass": { "type": "string" },
        "surfaceObjectKind": { "type": "string" }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "areas"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "pattern": {
          "type": "string",
          "enum": [
            "stack",
            "split",
            "tabs",
            "grid",
            "sidebar-content",
            "dashboard",
            "modal",
            "sheet",
            "focus-detail",
            "desktop-zones"
          ],
          "description": "Renderer intent hint. Keeps skill manifests declarative without requiring renderer-specific CSS."
        },
        "areas": { "type": "array", "items": { "$ref": "#/$defs/area" } }
      }
    },
    "area": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "role": { "type": "string" },
        "label": { "type": "string" }
      }
    },

    "widgetConfig": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "area"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "$ref": "#/$defs/widgetType" },
        "area": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "dataSource": { "$ref": "#/$defs/dataSource" },
        "inputs": { "type": "object", "additionalProperties": true },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
        "load": { "$ref": "#/$defs/loadHint" },
        "loading": { "$ref": "#/$defs/loadingBehavior" },
        "interaction": { "$ref": "#/$defs/interactionBehavior" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "visual.frameViewer" } } },
          "then": {
            "properties": {
              "inputs": { "$ref": "#/$defs/frameViewerInputs" }
            }
          }
        }
      ]
    },

    "dataSource": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["skill", "api", "static", "resource", "y", "stream"] },
        "name": {
          "type": "string",
          "description": "Skill data source target in '<skill>.<method>' form."
        },
        "url": { "type": "string" },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "params": { "type": "object", "additionalProperties": true },
        "body": {},
        "value": {},
        "resource": {
          "$ref": "#/$defs/id",
          "description": "Resource id from top-level resources when kind='resource'."
        },
        "path": { "type": "string" },
        "nodeId": {
          "type": "string",
          "description": "Optional node id or state template for node-scoped stream/Yjs sources."
        },
        "transform": { "type": "string" },
        "observeRoot": {
          "type": "boolean",
          "description": "For Yjs data sources, observe the root data map and read the declared path from it. Use when a skill replaces a plain JSON subtree."
        },
        "observe": {
          "type": "string",
          "enum": ["path", "dataRoot"],
          "description": "Observation strategy for Yjs data sources. dataRoot is equivalent to observeRoot=true."
        },
        "receiver": { "$ref": "#/$defs/id" },
        "scope": {
          "type": "string",
          "enum": ["auto", "node", "shared", "local", "workspace"],
          "description": "Addressing intent for node-aware modal opens. Shared streams and shared Yjs branches are not node-scoped."
        },
        "transport": {
          "type": "string",
          "enum": ["auto", "member", "hub"],
          "description": "Preferred stream transport. Receiver-level transport is used when omitted or set to auto."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "skill" } } },
          "then": { "required": ["name"] }
        },
        {
          "if": { "properties": { "kind": { "const": "api" } } },
          "then": { "required": ["url"] }
        },
        {
          "if": { "properties": { "kind": { "const": "static" } } },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "kind": { "const": "resource" } } },
          "then": { "required": ["resource"] }
        },
        {
          "if": { "properties": { "kind": { "const": "stream" } } },
          "then": { "required": ["receiver"] }
        }
      ]
    },

    "autoAction": {
      "type": "object",
      "additionalProperties": true,
      "required": ["action"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "intervalMs": {
          "type": "integer",
          "minimum": 1,
          "description": "Requested interval. The client clamps very small values to a safe minimum."
        },
        "enabledIf": {
          "type": "string",
          "description": "Client state expression evaluated before each tick."
        },
        "action": { "$ref": "#/$defs/action" }
      }
    },
    "actionFeedback": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pending": { "$ref": "#/$defs/pendingFeedback" },
        "observe": { "$ref": "#/$defs/actionObservation" },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1,
          "description": "Fallback timeout when observe.timeoutMs is omitted."
        },
        "timeout": {
          "type": "object",
          "additionalProperties": true,
          "description": "Fallback state/message when observation does not complete."
        },
        "success": {
          "type": "object",
          "additionalProperties": true
        },
        "error": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "pendingFeedback": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disable": {
          "type": "boolean",
          "default": true,
          "description": "Disable the triggering control while the action is awaiting feedback."
        },
        "label": { "type": "string" },
        "icon": {
          "type": "string",
          "description": "Ionicon name or resource:<id> for the pending state."
        },
        "state": { "type": "string" }
      }
    },
    "actionObservation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["y", "stream"] },
        "path": {
          "type": "string",
          "description": "Yjs path for kind='y' or JSON pointer/dot path into the stream value for kind='stream'."
        },
        "receiver": {
          "$ref": "#/$defs/id",
          "description": "Stream receiver for kind='stream'."
        },
        "key": {
          "type": "string",
          "description": "Expected item key for kind='stream' when path selects a collection. Supports runtime tokens such as $event.name."
        },
        "idField": {
          "type": "string",
          "minLength": 1,
          "description": "Item field used with key for kind='stream'. Defaults to name."
        },
        "id_field": {
          "type": "string",
          "minLength": 1,
          "description": "Legacy spelling accepted for existing _observe-style manifests."
        },
        "mode": {
          "type": "string",
          "enum": ["change", "patch", "snapshot"],
          "description": "Observation mode hint. Patch waits for a structural stream patch or the resulting collection value."
        },
        "scope": {
          "type": "string",
          "enum": ["auto", "node", "shared", "local", "workspace"]
        },
        "transport": {
          "type": "string",
          "enum": ["auto", "member", "hub"]
        },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1,
          "description": "Legacy spelling accepted for existing _observe-style manifests."
        },
        "match": {
          "type": "object",
          "additionalProperties": true
        },
        "advanceFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "updatedAtField": { "type": "string", "minLength": 1 },
        "sequenceField": { "type": "string", "minLength": 1 }
      }
    },

    "fieldPath": {
      "type": "string",
      "minLength": 1,
      "description": "Dot-separated path read from the current widget payload or page state."
    },

    "frameViewerInputs": {
      "type": "object",
      "additionalProperties": true,
      "description": "Inputs for visual.frameViewer. Payloads may provide image.media as a browser-routed media descriptor or image.src/src/url/base64 for local previews.",
      "properties": {
        "imageField": {
          "$ref": "#/$defs/fieldPath",
          "description": "Payload path for a direct image URL/data URL. Defaults to image.src."
        },
        "fullscreenMediaField": {
          "$ref": "#/$defs/fieldPath",
          "description": "Payload path for the high-quality fullscreen media descriptor. Defaults include image.fullscreen_media."
        },
        "prefetchMediaField": {
          "$ref": "#/$defs/fieldPath",
          "description": "Payload path for the next media descriptor to prefetch while fullscreen is open. Defaults include image.next_media."
        },
        "aspectRatio": {
          "type": "string",
          "description": "CSS aspect-ratio token for the inline frame stage, e.g. '16 / 9'."
        },
        "fullscreenOnClick": {
          "type": "boolean",
          "description": "Open the frame viewer fullscreen surface when the image is clicked/tapped."
        },
        "nativeFullscreen": {
          "type": "boolean",
          "description": "Request browser native fullscreen after opening the runtime fullscreen surface."
        },
        "retainLastImageOnEmpty": {
          "type": "boolean",
          "description": "Keep the last loaded image when a stream update omits image data."
        },
        "emptyText": { "type": "string" },
        "alt": { "type": "string" },
        "headerActions": {
          "type": "array",
          "items": { "$ref": "#/$defs/frameActionButton" }
        },
        "fullscreenActions": {
          "type": "array",
          "items": { "$ref": "#/$defs/frameActionButton" }
        },
        "keyboardActions": { "$ref": "#/$defs/keyActionMap" },
        "swipeActions": { "$ref": "#/$defs/swipeActionMap" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metricBinding" }
        },
        "metricItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/metricBinding" }
        }
      }
    },

    "frameActionButton": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string" },
        "icon": {
          "type": "string",
          "description": "Ionicon token. The client provides compact glyph fallbacks when icons are unavailable."
        },
        "glyph": { "type": "string" },
        "labelField": {
          "$ref": "#/$defs/fieldPath",
          "description": "Payload path that overrides label at render time."
        },
        "iconField": {
          "$ref": "#/$defs/fieldPath",
          "description": "Payload path that overrides icon at render time."
        },
        "idField": {
          "$ref": "#/$defs/fieldPath",
          "description": "Payload path that overrides action id at render time."
        },
        "local": {
          "type": "string",
          "description": "Client-local frame action. Currently supported: closeFullscreen."
        },
        "kind": { "type": "string" }
      }
    },

    "keyActionMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/id" },
      "description": "Map from KeyboardEvent.key to a widget action id."
    },

    "swipeActionMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "left": { "$ref": "#/$defs/id" },
        "right": { "$ref": "#/$defs/id" },
        "up": { "$ref": "#/$defs/id" },
        "down": { "$ref": "#/$defs/id" }
      }
    },

    "metricBinding": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": { "type": "string" },
        "path": { "$ref": "#/$defs/fieldPath" },
        "field": { "$ref": "#/$defs/fieldPath" }
      }
    },

    "mediaDescriptor": {
      "type": "object",
      "additionalProperties": true,
      "description": "Browser-facing media reference carried in stream payloads, commonly at image.media. WebUI streams should prefer this over inline base64 for large media.",
      "properties": {
        "route": {
          "type": "string",
          "enum": ["hub_browser_media", "root_media_relay", "node_media_file"],
          "description": "Runtime route the browser should use to resolve the media object."
        },
        "browser_route": {
          "type": "string",
          "enum": ["hub_browser_media", "root_media_relay", "node_media_file"]
        },
        "path": { "type": "string" },
        "browser_path": { "type": "string" },
        "content_path": { "type": "string" },
        "url": { "type": "string" },
        "node_url": { "type": "string" },
        "browser_url": { "type": "string" },
        "filename": { "type": "string" },
        "mime": { "type": "string" },
        "size_bytes": { "type": "integer", "minimum": 0 }
      }
    },

    "webio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "receivers": {
          "type": "object",
          "description": "Transport-independent browser stream receivers resolved by runtime and exposed to widgets via dataSource.kind='stream'.",
          "additionalProperties": { "$ref": "#/$defs/webioReceiver" }
        }
      }
    },

    "webioReceiver": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["replace", "append"],
          "description": "How incoming stream payloads update local client state."
        },
        "collectionKey": {
          "type": "string",
          "minLength": 1,
          "description": "For append mode, the array field that accumulates incoming items."
        },
        "dedupeBy": {
          "type": "string",
          "minLength": 1,
          "description": "Optional item field used to replace an existing item instead of appending a duplicate."
        },
        "idField": {
          "type": "string",
          "minLength": 1,
          "description": "Collection item identity field used by structural stream patches. Defaults to dedupeBy or name."
        },
        "itemPath": {
          "type": "string",
          "minLength": 1,
          "description": "Collection path updated by structural stream patches. JSON pointer paths such as /items are supported."
        },
        "patches": {
          "type": "boolean",
          "description": "Whether the receiver may publish adaos.stream.patch.v1 envelopes in addition to full snapshots."
        },
        "maxItems": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional local ring-buffer limit for append mode."
        },
        "initialState": {
          "description": "Optional initial client-side receiver state before the first stream event arrives."
        },
        "transport": {
          "type": "string",
          "enum": ["auto", "member", "hub"],
          "description": "Default transport for widgets observing this receiver."
        },
        "snapshotPolicy": {
          "type": "string",
          "enum": ["none", "on_subscribe", "on_subscribe_if_stale", "manual"],
          "description": "How the receiver recovers initial state after subscribe/resubscribe."
        },
        "ttlMs": {
          "type": "integer",
          "minimum": 1,
          "description": "Freshness TTL for replace-mode stream variables."
        },
        "sequenceField": {
          "type": "string",
          "minLength": 1,
          "description": "Field used to reject stale or duplicate stream payloads."
        },
        "updatedAtField": {
          "type": "string",
          "minLength": 1,
          "description": "Field carrying the producer timestamp for freshness checks."
        },
        "budget": {
          "$ref": "#/$defs/streamBudget",
          "description": "Declared receiver budget used by review, diagnostics, and future stream guards."
        },
        "guardVisibility": {
          "$ref": "#/$defs/guardVisibility",
          "description": "Operator-visible degraded/quarantine behavior when receiver budgets are exceeded."
        },
        "route": {
          "$ref": "#/$defs/streamRoute",
          "description": "Reviewable data-route metadata for this receiver."
        }
      }
    },

    "streamBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxPayloadBytes": { "type": "integer", "minimum": 1 },
        "maxPublishHz": { "type": "number", "exclusiveMinimum": 0 },
        "coalesceMs": { "type": "integer", "minimum": 0 },
        "maxFanout": { "type": "integer", "minimum": 1 },
        "maxSnapshotHz": { "type": "number", "exclusiveMinimum": 0 },
        "maxItems": { "type": "integer", "minimum": 1 }
      }
    },

    "guardVisibility": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "degradedState": { "type": "string", "minLength": 1 },
            "log": { "type": "string", "minLength": 1 },
            "quarantine": { "type": "boolean" },
            "metric": { "type": "string", "minLength": 1 },
            "correlationId": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },

    "streamRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "stream"
        },
        "surface": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "firstPaint": { "type": "string", "minLength": 1 },
        "recovery": { "type": "string", "minLength": 1 },
        "updateSource": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            }
          ]
        }
      }
    },

    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "on": { "type": "string", "description": "Trigger name (e.g. 'select')." },
        "id": {
          "$ref": "#/$defs/id",
          "description": "Stable action id used by defaultAction, submit, keyboard, and feedback contracts."
        },
        "label": { "type": "string" },
        "icon": {
          "type": "string",
          "description": "Ionicon name or resource:<id>."
        },
        "type": { "type": "string", "minLength": 1, "description": "Action type (e.g. 'callHost')." },
        "target": { "type": "string" },
        "params": { "type": "object", "additionalProperties": true },
        "feedback": { "$ref": "#/$defs/actionFeedback" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "openModal" } } },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/openModalActionParams" }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "openOverlay" } } },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/openOverlayActionParams" }
            }
          }
        }
      ]
    },

    "openModalActionParams": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "modalId": { "$ref": "#/$defs/id" },
        "id": { "$ref": "#/$defs/id" },
        "presentation": { "$ref": "#/$defs/overlayPresentation" },
        "focus": { "$ref": "#/$defs/overlayFocusPolicy" },
        "restoreFocus": {
          "type": "boolean",
          "description": "Per-open shortcut for presentation.focus.restoreOrigin."
        }
      }
    },

    "openOverlayActionParams": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "overlayId": { "$ref": "#/$defs/id" },
        "id": { "$ref": "#/$defs/id" },
        "presentation": { "$ref": "#/$defs/overlayPresentation" },
        "focus": { "$ref": "#/$defs/overlayFocusPolicy" },
        "restoreFocus": {
          "type": "boolean",
          "description": "Per-open shortcut for presentation.focus.restoreOrigin."
        }
      }
    },

    "contribution": {
      "type": "object",
      "additionalProperties": true,
      "required": ["extensionPoint", "type", "id"],
      "properties": {
        "extensionPoint": {
          "type": "string",
          "minLength": 1,
          "description": "Known: 'desktop.apps' | 'desktop.widgets'."
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "Known: 'app' | 'widget'."
        },
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "icon": { "type": "string" },
        "launchModal": { "$ref": "#/$defs/id" },
        "action": { "$ref": "#/$defs/launchAction" },
        "autoInstall": { "type": "boolean", "default": false }
      }
    }
  }
}

