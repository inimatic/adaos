{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"required": ["name", "version"],
	"properties": {
		"name": { "type": "string", "minLength": 1 },
		"version": { "type": "string", "minLength": 1 },
		"description": { "type": "string" },
		"llm_hints": {
			"$ref": "#/$defs/authoringHints",
			"description": "Builder-readable capability hints used by AI-assisted and human authoring workflows."
		},
		"nlu_hints": {
			"$ref": "#/$defs/authoringHints",
			"description": "Builder-readable NLU hints for aliases, examples, slot schemas, entities, and owner routing."
		},
		"runtime": {
			"type": "object",
			"properties": {
				"python": { "type": "string" }
			},
			"additionalProperties": true
		},
		"dependencies": {
			"type": "array",
			"items": { "type": "string", "minLength": 1 },
			"uniqueItems": true
		},
		"default_tool": {
			"type": "string"
		},
		"events": {
			"type": "object",
			"properties": {
				"subscribe": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"uniqueItems": true
				},
				"publish": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"uniqueItems": true
				}
			},
			"additionalProperties": false
		},
		"exports": {
			"type": "object",
			"properties": {
				"tools": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"uniqueItems": true
				}
			},
			"additionalProperties": true
		},
		"tools": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "input_schema"],
				"properties": {
					"name": { "type": "string", "minLength": 1 },
					"description": { "type": "string" },
					"entry": { "type": "string" },
					"input_schema": { "type": "object" },
					"output_schema": { "type": "object" }
				},
				"additionalProperties": true
			},
			"uniqueItems": true
		},
		"data_projections": {
			"description": "Optional data projection rules that map (scope, slot) pairs to storage backends. Skills may define defaults here; scenarios can override them.",
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"scope": { "type": "string" },
					"slot": { "type": "string" },
					"targets": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": true,
							"properties": {
								"backend": {
									"type": "string",
									"enum": ["yjs", "kv", "sql"]
								},
								"webspace_id": { "type": "string" },
								"path": { "type": "string" },
								"table": { "type": "string" },
								"column": { "type": "string" }
							},
							"required": ["backend"]
						}
					}
				},
				"required": ["scope", "slot"]
			}
		},
		"data_routes": {
			"description": "Reviewable browser-facing data route plan. Each entry states whether a surface uses Yjs, stream, details/tool, skill-local storage, or diagnostic logs, plus the expected budget and guard visibility.",
			"type": "array",
			"items": { "$ref": "#/$defs/dataRoute" }
		},
		"nlu": {
			"type": "object",
			"additionalProperties": true,
			"properties": {
				"llm_hints": { "$ref": "#/$defs/authoringHints" },
				"nlu_hints": { "$ref": "#/$defs/authoringHints" }
			}
		}
	},
	"$defs": {
		"authoringHints": {
			"type": "object",
			"additionalProperties": true,
			"properties": {
				"description": { "type": "string" },
				"aliases": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"uniqueItems": true
				},
				"primary_actions": {
					"type": "array",
					"items": { "$ref": "#/$defs/authoringActionHint" }
				},
				"actions": {
					"type": "array",
					"items": { "$ref": "#/$defs/authoringActionHint" }
				},
				"examples": {
					"type": "array",
					"items": {
						"oneOf": [
							{ "type": "string", "minLength": 1 },
							{ "$ref": "#/$defs/authoringExample" }
						]
					}
				},
				"slot_schemas": {
					"type": "object",
					"additionalProperties": true
				},
				"entities": {
					"type": "array",
					"items": {
						"oneOf": [
							{ "type": "string", "minLength": 1 },
							{ "$ref": "#/$defs/authoringEntityHint" }
						]
					}
				},
				"owner_hints": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"uniqueItems": true
				},
				"side_effect_class": {
					"type": "string",
					"enum": ["none", "read_only", "local_write", "runtime_write", "external_io", "destructive"]
				},
				"notes": { "type": "string" }
			}
		},
		"authoringActionHint": {
			"type": "object",
			"additionalProperties": true,
			"properties": {
				"id": { "type": "string", "minLength": 1 },
				"label": { "type": "string", "minLength": 1 },
				"description": { "type": "string" },
				"intent": { "type": "string", "minLength": 1 },
				"tool": { "type": "string", "minLength": 1 },
				"event": { "type": "string", "minLength": 1 },
				"slots": { "type": "object", "additionalProperties": true },
				"examples": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 }
				},
				"side_effect_class": {
					"type": "string",
					"enum": ["none", "read_only", "local_write", "runtime_write", "external_io", "destructive"]
				}
			}
		},
		"authoringExample": {
			"type": "object",
			"additionalProperties": true,
			"properties": {
				"text": { "type": "string", "minLength": 1 },
				"locale": { "type": "string", "minLength": 1 },
				"intent": { "type": "string", "minLength": 1 },
				"slots": { "type": "object", "additionalProperties": true }
			},
			"required": ["text"]
		},
		"authoringEntityHint": {
			"type": "object",
			"additionalProperties": true,
			"properties": {
				"kind": { "type": "string", "minLength": 1 },
				"canonical_ref": { "type": "string", "minLength": 1 },
				"aliases": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 }
				}
			}
		},
		"dataRoute": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"surface": { "type": "string", "minLength": 1 },
				"route": {
					"type": "string",
					"enum": ["yjs", "stream", "tool", "details", "tool/details", "skill-local", "disk", "360log", "disk/360log"],
					"description": "Status cards/statusPlane are compact indexes over these routes, not valid data routes."
				},
				"owner": { "type": "string", "minLength": 1 },
				"path": { "type": "string", "minLength": 1 },
				"receiver": { "type": "string", "minLength": 1 },
				"projection_slot": { "type": "string", "minLength": 1 },
				"first_paint": { "type": "string", "minLength": 1 },
				"recovery": { "type": "string", "minLength": 1 },
				"update_source": {
					"oneOf": [
						{ "type": "string", "minLength": 1 },
						{
							"type": "array",
							"items": { "type": "string", "minLength": 1 },
							"minItems": 1
						}
					]
				},
				"budget": { "$ref": "#/$defs/dataRouteBudget" },
				"guard_visibility": { "$ref": "#/$defs/guardVisibility" },
				"notes": { "type": "string" }
			},
			"required": ["surface", "route"]
		},
		"dataRouteBudget": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"max_payload_bytes": { "type": "integer", "minimum": 1 },
				"max_publish_hz": { "type": "number", "exclusiveMinimum": 0 },
				"coalesce_ms": { "type": "integer", "minimum": 0 },
				"max_fanout": { "type": "integer", "minimum": 1 },
				"max_items": { "type": "integer", "minimum": 1 },
				"ttl_ms": { "type": "integer", "minimum": 1 },
				"snapshot_policy": {
					"type": "string",
					"enum": ["none", "on_subscribe", "on_subscribe_if_stale", "manual"]
				}
			}
		},
		"guardVisibility": {
			"oneOf": [
				{ "type": "string", "minLength": 1 },
				{
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"degraded_state": { "type": "string", "minLength": 1 },
						"log": { "type": "string", "minLength": 1 },
						"quarantine": { "type": "boolean" },
						"metric": { "type": "string", "minLength": 1 },
						"correlation_id": { "type": "string", "minLength": 1 }
					}
				}
			]
		}
	},
	"additionalProperties": true
}
